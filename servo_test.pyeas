import time
import pigpio

SERVO_GPIO = 18  # GPIO18 (pin 12)

pi = pigpio.pi()
if not pi.connected:
    raise RuntimeError("pigpio not connected. Start it: sudo systemctl start pigpiod")

def set_us(us):
    pi.set_servo_pulsewidth(SERVO_GPIO, us)

try:
    set_us(1500)  # center
    time.sleep(1)

    set_us(1100)  # left
    time.sleep(1)

    set_us(1900)  # right
    time.sleep(1)

    set_us(1500)  # center
    time.sleep(1)

finally:
    pi.set_servo_pulsewidth(SERVO_GPIO, 0)  # stop pulses
    pi.stop()
